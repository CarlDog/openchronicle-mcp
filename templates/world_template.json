  "template_info": {
    "name": "OpenChronicle World Template",
    "description": "Adaptable world-building template for comprehensive storytelling environments",
    "version": "1.0",
    "purpose": "Provides comprehensive world creation with regional structures, magical systems, and temporal mechanics",
    "required_fields": ["world_overview.world_name"],
    "optional_fields": "Any field marked with '_optional': true can be safely deleted",
    "usage": "Delete entire fields/sections with '_optional': true, or just the '_optional' key to make field required",
    "import_adaptability": {
      "arrays_expandable": "All arrays can contain any number of entries - template shows minimum structure",
      "dynamic_regions": "Regional structure can expand to accommodate any number of areas",
      "unlimited_modifications": "All systems (magical, temporal, cultural) can grow as needed",
      "flexible_structure": "Import processes should expand arrays and adapt field counts dynamically"
    },
    "application_behavior": {
      "empty_optional_fields": "Application will automatically ignore optional fields that are empty, null, or contain only placeholder values",
      "unused_optional_fields": "Optional fields left as {{PLACEHOLDER}} values will be treated as unused and ignored",
      "processing_logic": "Only populated optional fields with actual content will be processed by the application"
    }
  },
