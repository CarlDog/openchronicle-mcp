# OpenChronicle v3 environment configuration.
#
# Copy to .env and edit. Every value shown is the dataclass default;
# uncomment to override. See docs/configuration/env_vars.md for the
# full reference.

# ──────────────────────────────────────────────
# Storage paths (Docker overrides these to /data, /config, /output)
# ──────────────────────────────────────────────
# OC_DATA_DIR=                       # Sets a root; per-path vars below derive from it
# OC_DB_PATH=data/openchronicle.db
# OC_CONFIG_DIR=config
# OC_OUTPUT_DIR=output

# ──────────────────────────────────────────────
# Embeddings (default: none = FTS5-only search)
# ──────────────────────────────────────────────
# OC_EMBEDDING_PROVIDER=none         # none | stub | openai | ollama
# OC_EMBEDDING_MODEL=text-embedding-3-small
# OC_EMBEDDING_DIMENSIONS=1536
# OC_EMBEDDING_TIMEOUT=30.0
# OC_EMBEDDING_API_KEY=              # Optional explicit override

# Provider-specific:
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# ──────────────────────────────────────────────
# HTTP API
# ──────────────────────────────────────────────
# OC_API_HOST=127.0.0.1              # 0.0.0.0 inside Docker
# OC_API_PORT=8000
# OC_API_KEY=                        # Bearer token (auth disabled when empty)
# OC_API_RATE_LIMIT_RPM=600

# ──────────────────────────────────────────────
# MCP server (when running standalone, not mounted in `oc serve`)
# ──────────────────────────────────────────────
# OC_MCP_TRANSPORT=stdio             # stdio | sse | streamable-http
# OC_MCP_HOST=127.0.0.1
# OC_MCP_PORT=8080

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
# OC_LOG_FORMAT=human                # human | json
# OC_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ──────────────────────────────────────────────
# Maintenance loop
# ──────────────────────────────────────────────
# OC_MAINTENANCE_DISABLED=           # Set to 1 / true / yes / on to disable

# ──────────────────────────────────────────────
# Search
# ──────────────────────────────────────────────
# OC_SEARCH_FTS5_ENABLED=1           # Set to 0 to force keyword-fallback path

# ──────────────────────────────────────────────
# Git onboarding
# ──────────────────────────────────────────────
# OC_GIT_TOKEN=                      # GitHub PAT for private-repo onboarding
